# Copy this file to ~/.config/runtime-guard/<instance>.env and customize.

# Absolute path to Python executable in the environment where runtime_guard is installed.
PYTHON_BIN=/home/YOUR_USER/YOUR_REPO/.venv/bin/python

# Absolute path to this repository's watcher script.
WATCHER_SCRIPT=/home/YOUR_USER/YOUR_REPO/scripts/runtime_guard_repo_watcher.py

# Absolute path to target repository root to monitor for process activity.
REPO_PATH=/home/YOUR_USER/YOUR_REPO

# Optional runtime-guard tuning.
STAGE=repo-background
INTERVAL_ACTIVE=15
INTERVAL_IDLE=60
COOLDOWN_S=30
LOG_TAG=runtime-guard
